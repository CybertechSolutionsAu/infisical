# Copy this file to scripts/.env and fill in your values.
# scripts/.env is gitignored.

# Your GitHub username (lowercase)
GHCR_USER=your-github-username

# GitHub Personal Access Token with write:packages, read:packages
# Create at: https://github.com/settings/tokens/new
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional overrides
# IMAGE_NAME=infisical
# ROLLING_TAG=latest-postgres
# DOCKERFILE=Dockerfile.standalone-infisical
